# =============================================================
# CONFIGURATION DU BACKEND — copiez ce fichier en ".env"
# Voir README.md pour le guide détaillé d'obtention de chaque valeur.
# =============================================================

# --- Monetbil (obligatoire pour encaisser les paiements) ---
MONETBIL_SERVICE_KEY=

# URL publique de votre backend une fois déployé (ex: https://monsite.com)
PUBLIC_BASE_URL=http://localhost:8000

# --- Lien vers votre template Railway pour le bot livré aux clients ---
RAILWAY_TEMPLATE_URL=https://railway.app/template/VOTRE-TEMPLATE-ID

# --- WhatsApp support (pour les liens pré-remplis vers vous) ---
SUPPORT_WHATSAPP_NUMBER=

# --- Sécurité des sessions admin (mettez une longue chaîne aléatoire) ---
SESSION_SECRET_KEY=changez-moi-en-production
